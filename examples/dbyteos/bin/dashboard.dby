fn dashboard_search(query: str):
if valid_search_text(query) == 0:
print("error: search: invalid query")
else:
let q_lower: str = to_lowercase(query)
print("--- DByteOS Dashboard Search: " + query + " ---")
let has_match: int = 0

if fs.exists(index_path) == 1:
let content: str = fs.read_text(index_path)
let line: str = ""
for c in content:
if c == "\n":
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
let p_lower: str = to_lowercase(clean_p)
if string_contains(p_lower, q_lower) == 1:
print("* [project] " + clean_p + " (registered)")
has_match = 1

# Search tasks for this project
let t_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/tasks.txt")
if fs.exists(t_path) == 1:
let t_content: str = fs.read_text(t_path)
let t_line: str = ""
let t_no: int = 1
for tc in t_content:
if tc == "\n":
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let text: str = ""
let sep: int = 0
for t_char in clean_t:
if sep == 0:
if t_char == "|":
sep = 1
else:
status = status + t_char
else:
text = text + t_char
let t_lower: str = to_lowercase(text)
if string_contains(t_lower, q_lower) == 1:
let status_str: str = "open"
if status == "1":
status_str = "done"
print("* [task] " + clean_p + " #" + int_to_str(t_no) + ": [" + status_str + "] " + text)
has_match = 1
t_line = ""
t_no = t_no + 1
else:
t_line = t_line + tc
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let text: str = ""
let sep: int = 0
for t_char in clean_t:
if sep == 0:
if t_char == "|":
sep = 1
else:
status = status + t_char
else:
text = text + t_char
let t_lower: str = to_lowercase(text)
if string_contains(t_lower, q_lower) == 1:
let status_str: str = "open"
if status == "1":
status_str = "done"
print("* [task] " + clean_p + " #" + int_to_str(t_no) + ": [" + status_str + "] " + text)
has_match = 1
line = ""
else:
line = line + c
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
let p_lower: str = to_lowercase(clean_p)
if string_contains(p_lower, q_lower) == 1:
print("* [project] " + clean_p + " (registered)")
has_match = 1

# Search tasks for this project
let t_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/tasks.txt")
if fs.exists(t_path) == 1:
let t_content: str = fs.read_text(t_path)
let t_line: str = ""
let t_no: int = 1
for tc in t_content:
if tc == "\n":
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let text: str = ""
let sep: int = 0
for t_char in clean_t:
if sep == 0:
if t_char == "|":
sep = 1
else:
status = status + t_char
else:
text = text + t_char
let t_lower: str = to_lowercase(text)
if string_contains(t_lower, q_lower) == 1:
let status_str: str = "open"
if status == "1":
status_str = "done"
print("* [task] " + clean_p + " #" + int_to_str(t_no) + ": [" + status_str + "] " + text)
has_match = 1
t_line = ""
t_no = t_no + 1
else:
t_line = t_line + tc
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let text: str = ""
let sep: int = 0
for t_char in clean_t:
if sep == 0:
if t_char == "|":
sep = 1
else:
status = status + t_char
else:
text = text + t_char
let t_lower: str = to_lowercase(text)
if string_contains(t_lower, q_lower) == 1:
