fn dashboard_snapshot():
print("--- DByteOS Dashboard: Snapshot ---")
print("User: " + profile.get_user())
print("OS Version: " + system.os_version)

let p_count: int = 0
let open_total: int = 0
let done_total: int = 0
if fs.exists(index_path) == 1:
let content: str = fs.read_text(index_path)
let line: str = ""
for c in content:
if c == "\n":
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
p_count = p_count + 1
open_total = open_total + count_tasks(clean_p, 0)
done_total = done_total + count_tasks(clean_p, 1)
line = ""
else:
line = line + c
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
p_count = p_count + 1
open_total = open_total + count_tasks(clean_p, 0)
done_total = done_total + count_tasks(clean_p, 1)

print("Projects: " + int_to_str(p_count))
print("Tasks: " + int_to_str(open_total) + " open / " + int_to_str(done_total) + " done")
print("Services: active")

if projects_path == "":
print("error: dashboard: internal path resolution failed")
else:
if len(args) < 1:
dashboard_home()
else:
let cmd: str = args[0]
if cmd == "projects":
dashboard_projects()
else:
if cmd == "tasks":
dashboard_tasks()
else:
if cmd == "search":
if len(args) < 2:
print("usage: dashboard search <query>")
else:
let query: str = profile.join_args_from(args, 1)
dashboard_search(query)
else:
if cmd == "timeline":
dashboard_timeline()
else:
if cmd == "health":
dashboard_health()
else:
if cmd == "snapshot":
dashboard_snapshot()
else:
if cmd == "help":
show_usage()
else:
print("error: unknown dashboard command: " + cmd)
show_usage()
