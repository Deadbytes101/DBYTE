if status == "1":
status_str = "done"
print("* [task] " + clean_p + " #" + int_to_str(t_no) + ": [" + status_str + "] " + text)
has_match = 1
if has_match == 0:
print("  (no matches found)")

fn dashboard_timeline():
print("--- DByteOS Dashboard: Timeline ---")
let is_cached: int = 0
let mode_str: str = "fallback"
let index_cache_path: str = profile.resolve_user_data_path("home/deadbyte/search_index.txt")
if fs.exists(index_cache_path) == 1:
is_cached = 1
mode_str = "cached"
print("Timeline Mode: " + mode_str)

let p_count: int = 0
let n_global: int = 0
let n_proj: int = 0
let j_count: int = 0
let t_open: int = 0
let t_done: int = 0

if fs.exists(index_path) == 1:
let content: str = fs.read_text(index_path)
let line: str = ""
for c in content:
if c == "\n":
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
p_count = p_count + 1

let n_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/notes.txt")
if fs.exists(n_path) == 1:
let n_content: str = fs.read_text(n_path)
let n_line: str = ""
for nc in n_content:
if nc == "\n":
if n_line != "":
n_proj = n_proj + 1
n_line = ""
else:
n_line = n_line + nc
if n_line != "":
n_proj = n_proj + 1

let t_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/tasks.txt")
if fs.exists(t_path) == 1:
let t_content: str = fs.read_text(t_path)
let t_line: str = ""
for tc in t_content:
if tc == "\n":
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let stop_parse: int = 0
for tc_c in clean_t:
if stop_parse == 0:
if tc_c == "|":
stop_parse = 1
else:
status = status + tc_c
if status == "1":
t_done = t_done + 1
else:
t_open = t_open + 1
t_line = ""
else:
t_line = t_line + tc
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let stop_parse: int = 0
for tc_c in clean_t:
if stop_parse == 0:
if tc_c == "|":
stop_parse = 1
else:
status = status + tc_c
if status == "1":
t_done = t_done + 1
else:
t_open = t_open + 1
line = ""
else:
line = line + c
if line != "":
let clean_p: str = strip_cr(line)
if valid_name(clean_p) == 1:
p_count = p_count + 1

let n_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/notes.txt")
if fs.exists(n_path) == 1:
let n_content: str = fs.read_text(n_path)
let n_line: str = ""
for nc in n_content:
if nc == "\n":
if n_line != "":
n_proj = n_proj + 1
n_line = ""
else:
n_line = n_line + nc
if n_line != "":
n_proj = n_proj + 1

let t_path: str = profile.resolve_user_data_path("home/deadbyte/projects/" + clean_p + "/tasks.txt")
if fs.exists(t_path) == 1:
let t_content: str = fs.read_text(t_path)
let t_line: str = ""
for tc in t_content:
if tc == "\n":
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let stop_parse: int = 0
for tc_c in clean_t:
if stop_parse == 0:
if tc_c == "|":
stop_parse = 1
else:
status = status + tc_c
if status == "1":
t_done = t_done + 1
else:
t_open = t_open + 1
t_line = ""
else:
t_line = t_line + tc
if t_line != "":
let clean_t: str = strip_cr(t_line)
let status: str = ""
let stop_parse: int = 0
for tc_c in clean_t:
if stop_parse == 0:
if tc_c == "|":
stop_parse = 1
else:
status = status + tc_c
if status == "1":
t_done = t_done + 1
else:
t_open = t_open + 1

let notes_path: str = profile.resolve_user_data_path("home/deadbyte/notes.txt")
if fs.exists(notes_path) == 1:
let content: str = fs.read_text(notes_path)
let line: str = ""
for c in content:
if c == "\n":
if line != "":
n_global = n_global + 1
line = ""
else:
line = line + c
if line != "":
n_global = n_global + 1

let journal_path: str = profile.resolve_user_data_path("home/deadbyte/journal.txt")
if fs.exists(journal_path) == 1:
let content: str = fs.read_text(journal_path)
let line: str = ""
for c in content:
if c == "\n":
if line != "":
j_count = j_count + 1
line = ""
else:
line = line + c
if line != "":
j_count = j_count + 1

print("Total Projects: " + int_to_str(p_count))
print("Total Notes:    " + int_to_str(n_global + n_proj))
print("Total Journal:  " + int_to_str(j_count))
print("Total Tasks:    " + int_to_str(t_open + t_done))

