# DByteOS Shell Configuration
# baseline aliases for the prototype environment

# System Commands
@shell alias boot = run boot.dby
@shell alias status = run bin/status.dby
@shell alias clean = run bin/clean.dby
@shell alias inspect = run bin/inspect.dby
@shell alias whoami = run bin/whoami.dby
@shell alias sysinfo = run bin/sysinfo.dby
@shell alias home = run bin/home.dby
@shell alias tmp = run bin/tmp.dby
@shell alias cat = run bin/cat.dby
@shell alias write-demo = run bin/write_demo.dby
@shell alias ls-sys = run bin/ls_sys.dby
@shell alias read = run bin/read.dby
@shell alias write = run bin/write.dby
@shell alias append = run bin/append.dby
@shell alias touch = run bin/touch.dby
@shell alias mkdir-demo = run bin/mkdir_demo.dby
@shell alias notes = run bin/notes.dby
@shell alias profile = run bin/profile.dby
@shell alias env = run bin/env.dby
@shell alias path = run bin/path.dby

# Navigation/Info (simulated)
@shell alias dir = ls
@shell alias whereami = pwd

# Tools from previous releases (mappable to OS bin)
@shell alias patch-demo = run ../sanctum/patch_demo.dby
@shell alias u32-demo = run ../sanctum/u32_demo.dby
@shell alias inspect-demo = run ../sanctum/inspect_demo.dby
