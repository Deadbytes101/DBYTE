import "./profile.dby" as profile
import std.fs as fs

pub fn path_has_dot_dot(p: str) -> int:
    let prev: str = ""
    for c in p:
        if prev == ".":
            if c == ".":
                return 1
        prev = c
    return 0

pub fn path_is_absolute(p: str) -> int:
    let idx: int = 0
    for c in p:
        if idx == 0:
            if c == "/":
                return 1
            if c == "\\":
                return 1
        if idx == 1:
            if c == ":":
                return 1
        idx = idx + 1
    return 0

pub fn has_prefix(raw: str, prefix: str) -> int:
    if len(raw) < len(prefix):
        return 0
    let out: str = ""
    let count: int = 0
    for c in raw:
        if count < len(prefix):
            out = out + c
        count = count + 1
    if out == prefix:
        return 1
    return 0

pub fn root_allowed_read(raw: str) -> int:
    if raw == "tmp":
        return 1
    if raw == "home/deadbyte":
        return 1
    if raw == "etc":
        return 1
    if raw == "sys":
        return 1
    if raw == "bin":
        return 1
    if raw == "boot.dby":
        return 1
    if raw == ".dbyterc":
        return 1
    if has_prefix(raw, "tmp/") == 1:
        return 1
    if has_prefix(raw, "home/deadbyte/") == 1:
        return 1
    if has_prefix(raw, "etc/") == 1:
        return 1
    if has_prefix(raw, "sys/") == 1:
        return 1
    if has_prefix(raw, "bin/") == 1:
        return 1
    return 0

pub fn root_allowed_write(raw: str) -> int:
    if raw == "tmp":
        return 1
    if raw == "home/deadbyte":
        return 1
    if has_prefix(raw, "tmp/") == 1:
        return 1
    if has_prefix(raw, "home/deadbyte/") == 1:
        return 1
    return 0

pub fn is_allowed(op: str, raw: str) -> int:
    if path_has_dot_dot(raw) == 1:
        return 0
    if path_is_absolute(raw) == 1:
        return 0
    if op == "read":
        return root_allowed_read(raw)
    if op == "write":
        return root_allowed_write(raw)
    if op == "append":
        return root_allowed_write(raw)
    return 0

pub fn denial_reason(raw: str) -> str:
    if path_has_dot_dot(raw) == 1:
        return "path escape"
    if path_is_absolute(raw) == 1:
        return "absolute path"
    return "policy"

pub fn denied_message(op: str, raw: str) -> str:
    let reason: str = denial_reason(raw)
    if reason == "path escape":
        return "error: permission denied: path escape " + raw
    if reason == "absolute path":
        return "error: permission denied: absolute path " + raw
    return "error: permission denied: " + op + " " + raw

pub fn log_denied(op: str, raw: str):
    let log_path: str = profile.resolve_path("tmp/security.log")
    let old: str = ""
    if fs.exists(log_path) == 1:
        old = fs.read_text(log_path)
    fs.write_text(log_path, old + "DENY " + op + " " + raw + "\n")

pub fn resolve_allowed_path(op: str, raw: str) -> str:
    if is_allowed(op, raw) == 0:
        return ""
    return profile.resolve_path(raw)
