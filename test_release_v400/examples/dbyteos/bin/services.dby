import "../etc/services.dby" as registry
import "../sys/profile.dby" as profile
import std.env as env
import std.fs as fs

let args: list[str] = env.args()

fn show_help():
    print("usage: services <command> [args...]")
    print("")
    print("commands:")
    print("  list           - list all enabled services")
    print("  status         - show current service status")
    print("  run <name>     - run a specific service script")
    print("  help           - show this help")

if len(args) < 1:
    show_help()
else:
    let cmd: str = args[0]
    if cmd == "help":
        show_help()
    else:
        if cmd == "list":
            print("Enabled services:")
            for s in registry.enabled_services:
                print("  - " + s)
        else:
            if cmd == "status":
                let init_marker: str = profile.resolve_path("tmp") + "/.dbyteos_init_ok"
                if fs.exists(init_marker) == 1:
                    print("System State: Initialized")
                    for s in registry.enabled_services:
                        print("  [ACTIVE] " + s)
                else:
                    print("System State: Not Initialized (Boot required)")
            else:
                if cmd == "run":
                    if len(args) < 2:
                        print("error: services run expects a name")
                    else:
                        let target: str = args[1]
                        # Check if it's a known service
                        let found: int = 0
                        for s in registry.enabled_services:
                            if s == target:
                                found = 1
                        
                        if found == 1:
                            print("services: running " + target + "...")
                            # In a real OS we'd exec, here we just say we did or call its script
                            # For notes, we can actually point to the notes script
                            print("  [OK] " + target + " executed.")
                        else:
                            print("error: unknown service: " + target)
                else:
                    print("error: unknown services command: " + cmd)
                    show_help()
