import "../sys/profile.dby" as profile
import "../sys/security.dby" as security
import std.fs as fs
import std.env as env

let args: list[str] = env.args()
if len(args) == 0:
    print("usage: cat <file>")
else:
    let raw: str = args[0]
    let i: int = 1
    while i < len(args):
        raw = raw + " " + args[i]
        i = i + 1
    
    if security.is_allowed("read", raw) == 1:
        let target: str = profile.resolve_os_file(raw)
        if fs.exists(target) == 1:
            print(fs.read_text(target))
        else:
            print("error: cat: no such file or directory:", raw)
    else:
        security.log_denied("cat", raw)
        print(security.denied_message("cat", raw))
