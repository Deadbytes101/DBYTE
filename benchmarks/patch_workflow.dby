import std.buffer as buf
import std.encoding as enc
let b = buf.from_bytes(b"\x00\x11\x22\x33\xDE\xAD\xBE\xEF\x44\x55\x66\x77")
let i: int = 0
while i < 100000:
let pos = buf.find(b, b"\xDE\xAD\xBE\xEF")
if pos >= 0:
buf.replace(b, pos, b"\x90\x90\x90\x90")
buf.replace(b, pos, b"\xDE\xAD\xBE\xEF")
i = i + 1
# print(enc.hex_encode(buf.to_bytes(b))
